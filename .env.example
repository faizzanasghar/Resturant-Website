# ========== DELIZIA CRAFT PIZZA - ENVIRONMENT VARIABLES ==========
# 
# Copy this file to .env and update the values for your environment
# DO NOT commit .env file to version control
#

# ========== SERVER CONFIGURATION ==========

# Server port (default: 3000)
PORT=3000

# Environment mode (development | production)
NODE_ENV=development

# ========== DATABASE CONFIGURATION ==========

# Database file location
DATABASE_PATH=./database.db

# ========== SECURITY CONFIGURATION ==========

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate a secure key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=your-secret-key-change-this-in-production-with-a-long-random-string

# JWT Token Expiration (default: 24h)
JWT_EXPIRES_IN=24h

# Bcrypt Salt Rounds (higher = slower but more secure)
BCRYPT_ROUNDS=10

# ========== CORS CONFIGURATION ==========

# Allowed origins for CORS
CORS_ORIGIN=http://localhost:3000

# ========== LOGGING CONFIGURATION ==========

# Log level (error | warn | info | debug)
LOG_LEVEL=info

# ========== EMAIL CONFIGURATION (For future use) ==========

# Email service (Gmail, SendGrid, etc.)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# ========== PAYMENT CONFIGURATION (For future use) ==========

# Stripe API Keys
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# ========== ANALYTICS (For future use) ==========

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-xxxxxxxxx-x

# ========== NOTES ==========

# 1. Keep sensitive data like SECRET_KEY and API keys in .env file
# 2. Never commit .env to version control
# 3. In production, use strong, long random strings for SECRET_KEY
# 4. Example secure key generation:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ========== HOW TO USE ==========

# For development:
# 1. Create a file named .env in your project root
# 2. Copy the values from this file
# 3. Update with your specific values
# 4. Install dotenv: npm install dotenv
# 5. Update server.js to load: require('dotenv').config()
# 6. Access variables: process.env.SECRET_KEY

# For production:
# 1. Set environment variables on your hosting platform
# 2. Most platforms (Heroku, AWS, etc.) provide UI for this
# 3. Or use: export SECRET_KEY="your-secure-key" (Linux/Mac)
# 4. Or use: set SECRET_KEY=your-secure-key (Windows)
